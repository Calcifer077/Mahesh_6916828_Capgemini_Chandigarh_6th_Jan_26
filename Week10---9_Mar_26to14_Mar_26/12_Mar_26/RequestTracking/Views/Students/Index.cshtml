@model StudentsViewModel

<h2>Students</h2>

<ul>
@foreach (var student in Model.Students)
{
    <li>@student</li>
}
</ul>

<h2>Request Logs</h2>

<table border="1">
<tr>
    <th>URL</th>
    <th>Execution Time (ms)</th>
    <th>Time</th>
</tr>

@foreach (var log in Model.Logs)
{
<tr>
    <td>@log.Url</td>
    <td>@log.ExecutionTime</td>
    <td>@log.Time</td>
</tr>
}

</table>