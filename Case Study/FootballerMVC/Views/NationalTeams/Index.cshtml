@model IEnumerable<FootballerMVC.Models.NationalTeam>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TeamName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Country)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Confederation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HeadCoach)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FIFA_Ranking)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TeamName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Country)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Confederation)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HeadCoach)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FIFA_Ranking)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.NationalTeamId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.NationalTeamId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.NationalTeamId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
