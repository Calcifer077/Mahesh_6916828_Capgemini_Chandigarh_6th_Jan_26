@model FootballerMVC.Models.NationalTeam

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>NationalTeam</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="NationalTeamId" />
            <div class="form-group">
                <label asp-for="TeamName" class="control-label"></label>
                <input asp-for="TeamName" class="form-control" />
                <span asp-validation-for="TeamName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Country" class="control-label"></label>
                <input asp-for="Country" class="form-control" />
                <span asp-validation-for="Country" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Confederation" class="control-label"></label>
                <input asp-for="Confederation" class="form-control" />
                <span asp-validation-for="Confederation" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="HeadCoach" class="control-label"></label>
                <input asp-for="HeadCoach" class="form-control" />
                <span asp-validation-for="HeadCoach" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FIFA_Ranking" class="control-label"></label>
                <input asp-for="FIFA_Ranking" class="form-control" />
                <span asp-validation-for="FIFA_Ranking" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
