<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>

    <!-- Navbar -->
    <nav class="border-bottom bg-white">
        <div class="container d-flex justify-content-between align-items-center py-2">

            <!-- Brand -->
            <a class="text-decoration-none text-dark fw-semibold"
               asp-controller="Home"
               asp-action="Index">
                BookStore
            </a>

            <!-- Left Links -->
            <div class="d-flex gap-3 small">
                <a class="text-muted text-decoration-none" asp-controller="Books" asp-action="Index">Books</a>
                <a class="text-muted text-decoration-none" asp-controller="Books" asp-action="Cart">Cart</a>
                <a class="text-muted text-decoration-none" asp-controller="Orders" asp-action="Index">Orders</a>

                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a class="text-dark text-decoration-none"
                       asp-controller="Admin"
                       asp-action="Index">
                        Admin
                    </a>
                }
            </div>

            <!-- Right Side -->
            <div class="d-flex gap-3 small align-items-center">
                @if (Context.Session.GetString("JwtToken") != null)
                {
                    <span class="text-muted">
                        @Context.Session.GetString("UserName")
                    </span>
                    <a class="text-dark text-decoration-none"
                       asp-controller="Auth"
                       asp-action="Logout">
                        Logout
                    </a>
                }
                else
                {
                    <a class="text-muted text-decoration-none"
                       asp-controller="Auth"
                       asp-action="Login">
                        Login
                    </a>
                    <a class="text-dark text-decoration-none"
                       asp-controller="Auth"
                       asp-action="Register">
                        Register
                    </a>
                }
            </div>

        </div>
    </nav>

    <!-- Content -->
    <div class="container py-4" style="max-width: 1000px;">

        <!-- Messages -->
        @if (TempData["Message"] != null)
        {
            <div class="border bg-light text-muted small px-3 py-2 mb-3 rounded-2">
                @TempData["Message"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="border bg-light text-muted small px-3 py-2 mb-3 rounded-2">
                @TempData["Error"]
            </div>
        }

        @RenderBody()

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>