@model List<OrderView>
@{
    ViewData["Title"] = "Manage Orders";
}

<div class="container py-4">

    <!-- Header -->
    <h5 class="mb-4 fw-semibold text-dark">Orders</h5>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="border-bottom">
                    <tr class="small text-muted">
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th class="text-end">Total</th>
                        <th>Status</th>
                        <th class="text-end">Update</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr class="border-bottom">
                            <td class="text-muted">@order.OrderId</td>
                            <td class="fw-medium">@order.CustomerName</td>
                            <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                            <td class="text-end">₹@order.TotalAmount</td>
                            <td>
                                <span class="px-2 py-1 border rounded small text-muted">
                                    @order.Status
                                </span>
                            </td>
                            <td class="text-end">
                                <form asp-action="UpdateOrderStatus"
                                      method="post"
                                      class="d-flex justify-content-end gap-2">

                                    <input type="hidden"
                                           name="orderId"
                                           value="@order.OrderId" />

                                    <select name="status"
                                            class="form-select form-select-sm"
                                            style="width:140px">
                                        <option>Pending</option>
                                        <option>Confirmed</option>
                                        <option>Shipped</option>
                                        <option>Delivered</option>
                                        <option>Cancelled</option>
                                    </select>

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-secondary">
                                        Save
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-muted">No orders yet.</div>
    }

</div>