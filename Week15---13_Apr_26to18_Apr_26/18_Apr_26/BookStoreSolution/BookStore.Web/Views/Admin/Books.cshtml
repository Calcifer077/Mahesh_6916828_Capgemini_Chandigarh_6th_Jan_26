@using BookStore.Shared
@model PaginatedResult<BookListItem>
@{
    ViewData["Title"] = "Manage Books";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0 fw-semibold">Books</h5>
        <a asp-action="CreateBook" class="btn btn-sm border px-3">Add Book</a>
    </div>

    <!-- Search -->
    <form method="get" class="mb-4">
        <div class="input-group input-group-sm" style="max-width: 280px;">
            <input type="text"
                   name="search"
                   value="@ViewBag.Search"
                   class="form-control border-end-0"
                   placeholder="Search..." />
            <button type="submit" class="btn border">Search</button>
        </div>
    </form>

    @if (Model != null && Model.Items.Any())
    {
        <!-- Table -->
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="border-bottom">
                    <tr class="small text-muted">
                        <th>ID</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Stock</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model.Items)
                    {
                        <tr class="border-bottom">
                            <td class="text-muted">@book.BookId</td>
                            <td class="fw-medium">@book.Title</td>
                            <td>@book.AuthorName</td>
                            <td>@book.CategoryName</td>
                            <td class="text-end">₹@book.Price</td>
                            <td class="text-end">@book.Stock</td>
                            <td class="text-end">
                                <a asp-action="EditBook"
                                   asp-route-id="@book.BookId"
                                   class="btn btn-sm border me-1">
                                    Edit
                                </a>
                                <form asp-action="DeleteBook"
                                      asp-route-id="@book.BookId"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Delete this book?')">
                                    <button type="submit"
                                            class="btn btn-sm border">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <nav class="mt-3">
            <ul class="pagination pagination-sm">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.Page ? "active" : "")">
                        <a class="page-link border text-dark"
                           href="?page=@i&search=@ViewBag.Search">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
    else
    {
        <div class="text-muted">No books found.</div>
    }

</div>