@model SalesReportView
@{
    ViewData["Title"] = "Sales Report";
}

<div class="container py-4">

    <!-- Header -->
    <h5 class="mb-4 fw-semibold">Sales Report</h5>

    <!-- Summary -->
    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="bg-light border rounded-2 p-3 h-100">
                <div class="text-muted small mb-1">Total Orders</div>
                <div class="fs-4 fw-semibold text-dark">@Model.TotalOrders</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="bg-light border rounded-2 p-3 h-100">
                <div class="text-muted small mb-1">Total Revenue</div>
                <div class="fs-4 fw-semibold text-dark">₹@Model.TotalRevenue</div>
            </div>
        </div>

    </div>

    <!-- Top Books -->
    <h6 class="mb-3 text-muted">Top Selling Books</h6>

    @if (Model.TopBooks.Any())
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="border-bottom">
                    <tr class="small text-muted">
                        <th>Title</th>
                        <th class="text-end">Total Sold</th>
                        <th class="text-end">Revenue</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.TopBooks)
                    {
                        <tr class="border-bottom">
                            <td class="fw-medium">@b.Title</td>
                            <td class="text-end">@b.TotalSold</td>
                            <td class="text-end">₹@b.Revenue</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-muted">No sales data available yet.</div>
    }

</div>