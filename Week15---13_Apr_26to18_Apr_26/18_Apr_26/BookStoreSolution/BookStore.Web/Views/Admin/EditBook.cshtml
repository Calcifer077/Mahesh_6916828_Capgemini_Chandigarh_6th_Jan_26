@model BookFormModel
@{
    ViewData["Title"] = "Edit Book";
    var bookId = ViewBag.BookId;
    var categories = ViewBag.Categories as List<CategoryView> ?? new();
    var authors = ViewBag.Authors as List<AuthorView> ?? new();
    var publishers = ViewBag.Publishers as List<PublisherView> ?? new();
}

<div class="container py-4" style="max-width: 600px;">

    <!-- Header -->
    <h5 class="mb-4 fw-semibold">Edit Book</h5>

    <form asp-action="EditBook" asp-route-id="@bookId" method="post">

        <div class="mb-3">
            <label asp-for="Title" class="form-label small text-muted"></label>
            <input asp-for="Title" class="form-control form-control-sm" />
        </div>

        <div class="mb-3">
            <label asp-for="ISBN" class="form-label small text-muted"></label>
            <input asp-for="ISBN" class="form-control form-control-sm" />
        </div>

        <div class="mb-3">
            <label asp-for="Price" class="form-label small text-muted"></label>
            <input asp-for="Price" class="form-control form-control-sm" type="number" step="0.01" />
        </div>

        <div class="mb-3">
            <label asp-for="Stock" class="form-label small text-muted"></label>
            <input asp-for="Stock" class="form-control form-control-sm" type="number" />
        </div>

        <div class="mb-3">
            <label asp-for="CategoryId" class="form-label small text-muted">Category</label>
            <select asp-for="CategoryId" class="form-select form-select-sm">
                @foreach (var c in categories)
                {
                    <option value="@c.CategoryId">@c.Name</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="AuthorId" class="form-label small text-muted">Author</label>
            <select asp-for="AuthorId" class="form-select form-select-sm">
                @foreach (var a in authors)
                {
                    <option value="@a.AuthorId">@a.Name</option>
                }
            </select>
        </div>

        <div class="mb-4">
            <label asp-for="PublisherId" class="form-label small text-muted">Publisher</label>
            <select asp-for="PublisherId" class="form-select form-select-sm">
                @foreach (var p in publishers)
                {
                    <option value="@p.PublisherId">@p.Name</option>
                }
            </select>
        </div>

        <!-- Actions -->
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-sm border px-3">
                Update
            </button>
            <a asp-action="Books" class="btn btn-sm border px-3">
                Cancel
            </a>
        </div>

    </form>

</div>