@model List<CartItem>
@{
    ViewData["Title"] = "Cart";
}

<div class="container py-4" style="max-width: 800px;">

    <!-- Header -->
    <h5 class="mb-4 fw-semibold">Shopping Cart</h5>

    @if (Model.Any())
    {
        <div class="table-responsive mb-3">
            <table class="table align-middle">
                <thead class="border-bottom">
                    <tr class="small text-muted">
                        <th>Book</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="border-bottom">
                            <td class="fw-medium">@item.Title</td>
                            <td class="text-end">₹@item.Price</td>
                            <td class="text-end">@item.Qty</td>
                            <td class="text-end">₹@(item.Price * item.Qty)</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="border-top">
                    <tr>
                        <th colspan="3" class="text-end text-muted">Total</th>
                        <th class="text-end fw-semibold">₹@Model.Sum(i => i.Price * i.Qty)</th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Action -->
        <form asp-action="Checkout" method="post">
            <button type="submit" class="btn btn-outline-secondary btn-sm">
                Place Order
            </button>
        </form>
    }
    else
    {
        <div class="text-muted">
            Your cart is empty.
            <a asp-controller="Books"
               asp-action="Index"
               class="text-dark text-decoration-none">
                Browse books
            </a>
        </div>
    }

</div>