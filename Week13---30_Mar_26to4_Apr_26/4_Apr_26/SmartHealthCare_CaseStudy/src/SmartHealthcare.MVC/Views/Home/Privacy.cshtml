@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="page-container">

    <h1>Privacy Policy</h1>
    <p class="muted">
        This page explains how your data is collected, used, and protected.
    </p>

    <div class="section">
        <h3>About This Application</h3>
        <p>
            This healthcare system helps manage patients, doctors, and appointments
            in a secure and efficient way.
        </p>
    </div>

    <div class="section">
        <h3>Data Privacy</h3>
        <p>
            We take your personal and medical information seriously. Your data is
            stored securely and only used for healthcare-related purposes.
        </p>
    </div>

    <div class="section">
        <h3>Policy Details</h3>
        <p>
            This includes how we collect data, how it is used, and your rights
            regarding your information. Contact support for any concerns.
        </p>
    </div>

</div>

<style>
    body {
        background: #f5f5f5;
        font-family: system-ui, -apple-system, sans-serif;
        color: #222;
    }

    .page-container {
        max-width: 700px;
        margin: 60px auto;
        padding: 0 16px;
    }

    h1 {
        font-weight: 600;
        margin-bottom: 10px;
    }

    .muted {
        color: #666;
        font-size: 14px;
        margin-bottom: 30px;
    }

    .section {
        margin-bottom: 24px;
        padding-bottom: 12px;
        border-bottom: 1px solid #e5e5e5;
    }

    .section h3 {
        font-size: 18px;
        margin-bottom: 6px;
    }

    .section p {
        color: #444;
        line-height: 1.6;
        font-size: 14px;
    }
</style>