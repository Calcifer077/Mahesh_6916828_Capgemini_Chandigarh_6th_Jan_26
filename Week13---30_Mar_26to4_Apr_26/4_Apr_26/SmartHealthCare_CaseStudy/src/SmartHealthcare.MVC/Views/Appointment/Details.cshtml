@model SmartHealthcare.Models.DTOs.AppointmentDTO
@{
    ViewData["Title"] = "Appointment Details";
    var prescription = ViewBag.Prescription as SmartHealthcare.Models.DTOs.PrescriptionDTO;
    var bill = ViewBag.Bill as SmartHealthcare.Models.DTOs.BillDTO;
    var role = ViewBag.Role as string;
    var isDoctor = role == "Doctor";
    var isPatient = role == "Patient";
    var hasNoRx = prescription == null;
    var isSuggested = prescription?.Status == "Suggested";
    var isFinalized = prescription?.Status == "Finalized";
    var appointmentIsPending = Model.Status == "Pending";
}

<div class="page-container">

    <a href="@Url.Action("Index")" class="back-link">← Back to Appointments</a>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error">@TempData["Error"]</div>
    }

    <!-- Appointment Card -->
    <div class="card">
        <div class="card-header">
            <div>
                <h2>Appointment #@Model.Id</h2>
                <span class="status status-@Model.Status.ToLower()">@Model.Status</span>
            </div>
        </div>
        <div class="card-body">
            <div class="grid">
                <div>
                    <h4>Patient</h4>
                    <p>@Model.PatientName</p>
                </div>
                <div>
                    <h4>Doctor</h4>
                    <p>Dr. @Model.DoctorName</p>
                </div>
            </div>
            <hr />
            <div class="grid">
                <div>
                    <h4>Date & Time</h4>
                    <p>@Model.AppointmentDate.ToString("dd MMM yyyy, HH:mm")</p>
                    <h4 class="mt">Created</h4>
                    <p>@Model.CreatedAt.ToString("dd MMM yyyy")</p>
                </div>
                <div>
                    <h4>Notes</h4>
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <p>@Model.Notes</p>
                    }
                    else
                    {
                        <p class="muted">No notes provided</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Prescription Section -->
    @if (hasNoRx && isDoctor && appointmentIsPending)
    {
        <!-- Doctor: no prescription yet, appointment is pending — show suggest form -->
        <div class="card">
            <div class="card-header">
                <h3>Add Prescription Suggestion</h3>
            </div>
            <div class="card-body">
                <form method="post" action="@Url.Action("SuggestPrescription", "Appointment")" id="prescriptionForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="appointmentId" value="@Model.Id" />

                    <div class="form-group">
                        <label>Diagnosis <span class="required">*</span></label>
                        <input type="text" name="Diagnosis" required maxlength="500" placeholder="Enter diagnosis" />
                    </div>

                    <div class="form-group">
                        <label>Notes</label>
                        <textarea name="Notes" rows="3" maxlength="1000" placeholder="Additional notes (optional)"></textarea>
                    </div>

                    <div class="section-label">Medicines</div>
                    <div id="medicineList"></div>

                    <button type="button" class="btn btn-outline" onclick="addMedicine()">+ Add Medicine</button>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Submit Suggestion</button>
                    </div>
                </form>
            </div>
        </div>
    }
    else if (hasNoRx && isDoctor && !appointmentIsPending)
    {
        <!-- Doctor: appointment completed but no prescription -->
        <div class="empty-state">
            This appointment is <strong>@Model.Status</strong>. No prescription was added.
        </div>
    }
    else if (prescription != null)
    {
        <!-- Prescription exists -->
        <div class="card">
            <div class="card-header space-between">
                <div>
                    <h3>Prescription</h3>
                    <span class="status status-@prescription.Status.ToLower()">@prescription.Status</span>
                </div>

                @if (isDoctor && isSuggested)
                {
                    <!-- Finalize form with medicine charges input -->
                    <form method="post" action="@Url.Action("FinalizePrescription", "Appointment")" class="finalize-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="prescriptionId" value="@prescription.Id" />
                        <input type="hidden" name="appointmentId" value="@Model.Id" />
                        <div class="finalize-row">
                            <div class="form-group mb-0">
                                <label>Medicine Charges (₹) <span class="required">*</span></label>
                                <input type="number" name="medicineCharges" min="0" max="100000"
                                       step="0.01" required placeholder="e.g. 200" />
                            </div>
                            <button type="submit" class="btn btn-success"
                                    onclick="return confirm('Finalize this prescription and generate bill? This cannot be undone.')">
                                ✓ Finalize & Generate Bill
                            </button>
                        </div>
                    </form>
                }
            </div>

            <div class="card-body">

                <div class="section">
                    <h4>Diagnosis</h4>
                    <p>@prescription.Diagnosis</p>
                </div>

                @if (!string.IsNullOrEmpty(prescription.Notes))
                {
                    <div class="section">
                        <h4>Notes</h4>
                        <p>@prescription.Notes</p>
                    </div>
                }

                @if (prescription.Medicines?.Count > 0)
                {
                    <div class="section">
                        <h4>Medicines</h4>
                        @foreach (var medicine in prescription.Medicines)
                        {
                            <div class="medicine">
                                <strong>@medicine.Name</strong>
                                <div class="medicine-meta">
                                    <span>Dosage: @medicine.Dosage</span>
                                    <span>Duration: @medicine.Duration</span>
                                </div>
                                @if (!string.IsNullOrEmpty(medicine.Instructions))
                                {
                                    <p class="muted">@medicine.Instructions</p>
                                }
                            </div>
                        }
                    </div>
                }

                @if (isFinalized)
                {
                    <p class="finalized-note">✓ This prescription has been finalized and is now visible to the patient.</p>
                }

            </div>
        </div>
    }
    else if (!isDoctor && hasNoRx)
    {
        <div class="empty-state">No prescription available for this appointment.</div>
    }

    <!-- Bill Section -->
    @if (bill != null)
    {
        <div class="card">
            <div class="card-header space-between">
                <div>
                    <h3>Bill</h3>
                    <span class="status status-@bill.PaymentStatus.ToLower()">@bill.PaymentStatus</span>
                </div>

                @if (isPatient && bill.PaymentStatus == "Unpaid")
                {
                    <form method="post" action="@Url.Action("PayBill", "Appointment")">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="billId" value="@bill.Id" />
                        <input type="hidden" name="appointmentId" value="@Model.Id" />
                        <button type="submit" class="btn btn-primary"
                                onclick="return confirm('Confirm payment of ₹@bill.TotalAmount?')">
                            Pay ₹@bill.TotalAmount
                        </button>
                    </form>
                }
            </div>

            <div class="card-body">
                <div class="grid">
                    <div>
                        <h4>Consultation Fee</h4>
                        <p>₹@bill.ConsultationFee</p>

                        <h4 class="mt">Medicine Charges</h4>
                        <p>₹@bill.MedicineCharges</p>

                        <h4 class="mt">Total Amount</h4>
                        <p class="total-amount">₹@bill.TotalAmount</p>
                    </div>
                    <div>
                        <h4>Billed On</h4>
                        <p>@bill.CreatedAt.ToString("dd MMM yyyy, HH:mm")</p>

                        @if (bill.PaidAt.HasValue)
                        {
                            <h4 class="mt">Paid On</h4>
                            <p>@bill.PaidAt.Value.ToString("dd MMM yyyy, HH:mm")</p>
                        }

                        @if (bill.PaymentStatus == "Paid")
                        {
                            <p class="finalized-note">✓ Payment received. Thank you!</p>
                        }
                        else if (isPatient)
                        {
                            <p class="unpaid-note">⚠ Payment pending. Please pay at your earliest convenience.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

</div>

@section Scripts {
<script>
    let medicineIndex = 0;

    function addMedicine() {
        const list = document.getElementById('medicineList');
        const idx = medicineIndex++;
        const div = document.createElement('div');
        div.className = 'medicine-row';
        div.id = `med-${idx}`;
        div.innerHTML = `
            <div class="medicine-row-header">
                <strong>Medicine ${idx + 1}</strong>
                <button type="button" class="btn-remove" onclick="removeMedicine(${idx})">✕ Remove</button>
            </div>
            <div class="med-grid">
                <div class="form-group">
                    <label>Name *</label>
                    <input type="text" name="Medicines[${idx}].Name" required maxlength="100" placeholder="Medicine name" />
                </div>
                <div class="form-group">
                    <label>Dosage *</label>
                    <input type="text" name="Medicines[${idx}].Dosage" required maxlength="100" placeholder="e.g. 500mg" />
                </div>
                <div class="form-group">
                    <label>Duration *</label>
                    <input type="text" name="Medicines[${idx}].Duration" required maxlength="50" placeholder="e.g. 7 days" />
                </div>
                <div class="form-group">
                    <label>Instructions</label>
                    <input type="text" name="Medicines[${idx}].Instructions" maxlength="300" placeholder="e.g. After meals" />
                </div>
            </div>
        `;
        list.appendChild(div);
    }

    function removeMedicine(idx) {
        document.getElementById(`med-${idx}`)?.remove();
    }
</script>
}

<style>
    body {
        background: #f7f7f7;
        font-family: system-ui, -apple-system, sans-serif;
        color: #222;
    }

    .page-container {
        max-width: 800px;
        margin: 40px auto;
        padding: 0 16px;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 16px;
        color: #555;
        text-decoration: none;
        font-size: 14px;
    }

    .back-link:hover { text-decoration: underline; }

    .alert {
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 16px;
        font-size: 14px;
    }

    .alert-success { background: #eaf7ee; color: #2f7a4a; border: 1px solid #b7e4c7; }
    .alert-error   { background: #fdecea; color: #a33;    border: 1px solid #f5c6c6; }

    .card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        margin-bottom: 16px;
    }

    .card-header {
        padding: 16px 20px;
        border-bottom: 1px solid #eee;
        display: flex;
        align-items: center;
    }

    .card-header.space-between {
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
    }

    .card-header h2, .card-header h3 { margin: 0; font-weight: 600; }

    .card-body { padding: 20px; }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    h4 { font-size: 14px; color: #666; margin-bottom: 4px; }
    p  { margin-bottom: 12px; font-size: 14px; }
    .mt { margin-top: 12px; }
    hr  { border: none; border-top: 1px solid #eee; margin: 16px 0; }
    .muted { color: #888; }

    .status {
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 6px;
        margin-left: 8px;
        background: #eee;
    }

    .status-pending   { background: #fff4e5; color: #a66b00; }
    .status-completed { background: #eaf7ee; color: #2f7a4a; }
    .status-cancelled { background: #fdecea; color: #a33; }
    .status-suggested { background: #e8f0fe; color: #1a56db; }
    .status-finalized { background: #eaf7ee; color: #2f7a4a; }
    .status-unpaid    { background: #fff4e5; color: #a66b00; }
    .status-paid      { background: #eaf7ee; color: #2f7a4a; }

    .section { margin-bottom: 16px; }
    .section-label { font-size: 14px; font-weight: 600; margin-bottom: 10px; color: #444; }

    .medicine {
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 10px;
    }

    .medicine-meta {
        font-size: 13px;
        color: #555;
        display: flex;
        gap: 12px;
        margin: 6px 0;
    }

    .empty-state {
        text-align: center;
        padding: 30px;
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        color: #777;
        margin-bottom: 16px;
    }

    /* Forms */
    .form-group {
        margin-bottom: 14px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .form-group.mb-0 { margin-bottom: 0; }

    .form-group label { font-size: 13px; font-weight: 500; color: #444; }
    .required { color: #c00; }

    .form-group input,
    .form-group textarea {
        padding: 8px 10px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 14px;
        font-family: inherit;
        outline: none;
        transition: border 0.2s;
    }

    .form-group input:focus,
    .form-group textarea:focus { border-color: #1a56db; }

    /* Finalize row — input + button side by side */
    .finalize-form { display: flex; align-items: flex-end; }

    .finalize-row {
        display: flex;
        align-items: flex-end;
        gap: 10px;
    }

    /* Medicine rows */
    .medicine-row {
        border: 1px solid #e5e5e5;
        border-radius: 10px;
        padding: 14px;
        margin-bottom: 12px;
        background: #fafafa;
    }

    .medicine-row-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

    .med-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    /* Buttons */
    .btn {
        padding: 9px 18px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        border: none;
        white-space: nowrap;
    }

    .btn-primary { background: #1a56db; color: #fff; }
    .btn-primary:hover { background: #1447c0; }

    .btn-success { background: #2f7a4a; color: #fff; }
    .btn-success:hover { background: #256040; }

    .btn-outline {
        background: transparent;
        border: 1px solid #1a56db;
        color: #1a56db;
    }

    .btn-outline:hover { background: #e8f0fe; }

    .btn-remove {
        background: transparent;
        border: none;
        color: #a33;
        font-size: 13px;
        cursor: pointer;
        padding: 4px 8px;
    }

    .btn-remove:hover { text-decoration: underline; }

    .form-actions { margin-top: 16px; }

    .finalized-note {
        margin-top: 12px;
        font-size: 13px;
        color: #2f7a4a;
        background: #eaf7ee;
        padding: 10px 14px;
        border-radius: 8px;
    }

    .unpaid-note {
        margin-top: 12px;
        font-size: 13px;
        color: #a66b00;
        background: #fff4e5;
        padding: 10px 14px;
        border-radius: 8px;
    }

    .total-amount {
        font-size: 18px;
        font-weight: 700;
        color: #222;
    }
</style>