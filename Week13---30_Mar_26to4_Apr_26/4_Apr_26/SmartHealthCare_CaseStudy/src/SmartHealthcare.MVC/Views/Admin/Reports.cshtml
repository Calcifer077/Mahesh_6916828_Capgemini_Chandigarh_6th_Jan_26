@{
    ViewData["Title"] = "Admin Reports";
}

<div class="page-container">

    <!-- Header -->
    <div class="page-header">
        <h2>Analytics & Reports</h2>
        <p>System statistics overview</p>
    </div>

    <div class="card">

        @if (ViewBag.Report != null)
        {
            <!-- Top Stats -->
            <div class="stats-grid">
                <div class="stat-card">
                    <span>Total Users</span>
                    <h3>@((dynamic)ViewBag.Report).TotalUsers</h3>
                </div>

                <div class="stat-card">
                    <span>Patients</span>
                    <h3>@((dynamic)ViewBag.Report).TotalPatients</h3>
                </div>

                <div class="stat-card">
                    <span>Doctors</span>
                    <h3>@((dynamic)ViewBag.Report).TotalDoctors</h3>
                </div>

                <div class="stat-card">
                    <span>Appointments</span>
                    <h3>@((dynamic)ViewBag.Report).TotalAppointments</h3>
                </div>
            </div>

            <!-- Appointment Stats -->
            <div class="section">
                <h4>Appointments</h4>
                <div class="stats-grid">
                    <div class="stat-card">
                        <span>Pending</span>
                        <h3>@((dynamic)ViewBag.Report).PendingAppointments</h3>
                    </div>

                    <div class="stat-card">
                        <span>Completed</span>
                        <h3>@((dynamic)ViewBag.Report).CompletedAppointments</h3>
                    </div>

                    <div class="stat-card">
                        <span>Cancelled</span>
                        <h3>@((dynamic)ViewBag.Report).CancelledAppointments</h3>
                    </div>
                </div>
            </div>

            <!-- Prescription -->
            <div class="section">
                <h4>Prescriptions</h4>
                <div class="stat-card single">
                    <span>Total Issued</span>
                    <h3>@((dynamic)ViewBag.Report).TotalPrescriptions</h3>
                </div>
            </div>

            <!-- Footer Info -->
            <div class="info-box">
                Last updated: @DateTime.Now.ToString("dd MMM yyyy, HH:mm")
            </div>
        }
        else
        {
            <div class="info-box warning">
                No reports available.
            </div>
        }

    </div>
</div>

<style>
    body {
        background: #f7f7f7;
        font-family: system-ui, -apple-system, sans-serif;
        color: #222;
    }

    .page-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 16px;
    }

    .page-header {
        margin-bottom: 24px;
    }

    .page-header h2 {
        margin-bottom: 4px;
        font-weight: 600;
    }

    .page-header p {
        color: #777;
        font-size: 14px;
    }

    .card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        padding: 24px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .section {
        margin-top: 24px;
    }

    .section h4 {
        margin-bottom: 12px;
        font-size: 16px;
        color: #555;
    }

    .stat-card {
        border: 1px solid #e5e5e5;
        border-radius: 10px;
        padding: 16px;
        background: #fafafa;
    }

    .stat-card span {
        display: block;
        font-size: 13px;
        color: #777;
        margin-bottom: 6px;
    }

    .stat-card h3 {
        margin: 0;
        font-weight: 600;
    }

    .stat-card.single {
        max-width: 200px;
    }

    .info-box {
        margin-top: 20px;
        font-size: 13px;
        color: #777;
    }

    .info-box.warning {
        color: #a66;
    }
</style>