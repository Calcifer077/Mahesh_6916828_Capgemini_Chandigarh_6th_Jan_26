@model SmartHealthcare.Models.DTOs.PagedResult<SmartHealthcare.Models.DTOs.DoctorDTO>

@{
    ViewData["Title"] = "Find a Doctor";
}

<div class="page-container">

    <h2>Find a Doctor</h2>

    <!-- Search -->
    <form method="get" class="search-bar">
        <input type="text" name="specialization" value="@ViewBag.Specialization" placeholder="Specialization" />
        <input type="text" name="name" value="@ViewBag.Name" placeholder="Doctor name" />
        <button type="submit">Search</button>
    </form>

    @if (Model?.Items != null && Model.Items.Any())
    {
        <!-- List -->
        <div class="doctor-list">
            @foreach (var doctor in Model.Items)
            {
                <div class="doctor-row">

                    <div class="doctor-main">
                        <div class="name">Dr. @doctor.FullName</div>
                        <div class="meta">
                            @string.Join(", ", doctor.Specializations ?? new List<string>())
                        </div>
                    </div>

                    <div class="doctor-info">
                        <div>@doctor.YearsOfExperience yrs</div>
                        <div>Rs. @doctor.ConsultationFee</div>
                        <div class="status">
                            @(doctor.IsAvailable ? "Available" : "Unavailable")
                        </div>
                    </div>

                    <div class="actions">
                        <a asp-action="Details" asp-route-id="@doctor.Id" class="btn">View</a>

                        @if (doctor.IsAvailable)
                        {
                            <a asp-controller="Appointment" asp-action="Create" class="btn primary">
                                Book
                            </a>
                        }
                    </div>

                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="pagination">

            @if (Model.PageNumber > 1)
            {
                <a href="?page=1&specialization=@ViewBag.Specialization&name=@ViewBag.Name">First</a>
                <a href="?page=@(Model.PageNumber - 1)&specialization=@ViewBag.Specialization&name=@ViewBag.Name">Prev</a>
            }

            <span>Page @Model.PageNumber</span>

            @if (Model.PageNumber * 10 < Model.TotalCount)
            {
                <a href="?page=@(Model.PageNumber + 1)&specialization=@ViewBag.Specialization&name=@ViewBag.Name">Next</a>
            }

        </div>
    }
    else
    {
        <div class="empty">
            <p>No doctors found.</p>
            <a href="@Url.Action("Index")" class="btn">Clear</a>
        </div>
    }

</div>

<style>
    body {
        background: #f5f5f5;
        font-family: system-ui, -apple-system, sans-serif;
        color: #222;
    }

    .page-container {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 16px;
    }

    h2 {
        margin-bottom: 16px;
        font-weight: 600;
    }

    /* Search */
    .search-bar {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    .search-bar input {
        flex: 1;
        padding: 8px 10px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    .search-bar button {
        padding: 8px 16px;
        border: none;
        background: #222;
        color: #fff;
        border-radius: 6px;
    }

    /* List */
    .doctor-list {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 10px;
    }

    .doctor-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        align-items: center;
        padding: 16px;
        border-bottom: 1px solid #eee;
    }

    .doctor-row:last-child {
        border-bottom: none;
    }

    .name {
        font-weight: 600;
    }

    .meta {
        font-size: 13px;
        color: #666;
    }

    .doctor-info {
        font-size: 14px;
        color: #444;
    }

    .status {
        font-size: 12px;
        margin-top: 4px;
        color: #666;
    }

    .actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .btn {
        padding: 6px 12px;
        border: 1px solid #ccc;
        border-radius: 6px;
        text-decoration: none;
        color: #222;
        background: #fff;
        font-size: 13px;
    }

    .btn.primary {
        background: #222;
        color: #fff;
        border-color: #222;
    }

    .btn:hover {
        background: #f0f0f0;
    }

    .btn.primary:hover {
        background: #000;
    }

    /* Pagination */
    .pagination {
        margin-top: 16px;
        display: flex;
        gap: 10px;
        justify-content: center;
        font-size: 14px;
    }

    .pagination a {
        text-decoration: none;
        color: #222;
    }

    /* Empty */
    .empty {
        text-align: center;
        padding: 40px;
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 10px;
    }
</style>