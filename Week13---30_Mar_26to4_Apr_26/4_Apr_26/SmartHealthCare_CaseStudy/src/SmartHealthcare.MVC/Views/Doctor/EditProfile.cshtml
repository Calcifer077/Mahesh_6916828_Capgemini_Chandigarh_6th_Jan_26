@model SmartHealthcare.Models.DTOs.UpdateDoctorDTO

@{
    ViewData["Title"] = "Edit Doctor Profile";
    var specializations = ViewBag.Specializations as IEnumerable<SmartHealthcare.Models.DTOs.SpecializationDTO> ?? Enumerable.Empty<SmartHealthcare.Models.DTOs.SpecializationDTO>();
}

<div class="page-container">

    <div class="form-card">
        <h2>Edit Profile</h2>
        <p class="muted">Update your professional details.</p>

        <form asp-action="Edit" method="post" novalidate>

            <div asp-validation-summary="All" class="error-box"></div>

            <div class="form-group">
                <label asp-for="LicenseNumber">License Number</label>
                <input asp-for="LicenseNumber" class="input" />
                <span asp-validation-for="LicenseNumber" class="error"></span>
            </div>

            <div class="grid">
                <div class="form-group">
                    <label asp-for="YearsOfExperience">Experience</label>
                    <input asp-for="YearsOfExperience" type="number" min="0" max="60" class="input" />
                    <span asp-validation-for="YearsOfExperience" class="error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConsultationFee">Fee (Rs)</label>
                    <input asp-for="ConsultationFee" type="number" step="0.01" min="0" class="input" />
                    <span asp-validation-for="ConsultationFee" class="error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Phone">Phone</label>
                <input asp-for="Phone" class="input" />
                <span asp-validation-for="Phone" class="error"></span>
            </div>

            <div class="form-group">
                <label>Specializations</label>
                <div class="checkbox-group">
                    @foreach (var spec in specializations)
                    {
                        <label class="checkbox-item">
                            <input type="checkbox"
                                   name="SpecializationIds"
                                   value="@spec.Id"
                                   @(Model.SpecializationIds.Contains(spec.Id) ? "checked" : "") />
                            @spec.Name
                        </label>
                    }
                </div>
                <span asp-validation-for="SpecializationIds" class="error"></span>
            </div>

            <div class="form-group checkbox-inline">
                <input asp-for="IsAvailable" type="checkbox" id="IsAvailable" />
                <label for="IsAvailable">Available for appointments</label>
            </div>

            <div class="actions">
                <button type="submit" class="btn primary">Save</button>
                <a href="@Url.Action("Profile", "Doctor")" class="btn">Cancel</a>
            </div>

        </form>
    </div>

</div>

<style>
    body {
        background: #f5f5f5;
        font-family: system-ui, -apple-system, sans-serif;
        color: #222;
    }

    .page-container {
        max-width: 600px;
        margin: 40px auto;
        padding: 0 16px;
    }

    .form-card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 10px;
        padding: 24px;
    }

    h2 {
        margin-bottom: 4px;
        font-weight: 600;
    }

    .muted {
        color: #666;
        font-size: 14px;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    label {
        display: block;
        font-size: 14px;
        margin-bottom: 6px;
        color: #444;
    }

    .input {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-size: 14px;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .checkbox-group {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .checkbox-item {
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .checkbox-inline {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .actions {
        margin-top: 20px;
        display: flex;
        gap: 10px;
    }

    .btn {
        padding: 8px 14px;
        border: 1px solid #ccc;
        border-radius: 6px;
        text-decoration: none;
        color: #222;
        background: #fff;
        font-size: 14px;
    }

    .btn.primary {
        background: #222;
        color: #fff;
        border-color: #222;
    }

    .btn:hover {
        background: #f0f0f0;
    }

    .btn.primary:hover {
        background: #000;
    }

    .error {
        color: #d00;
        font-size: 12px;
    }

    .error-box {
        background: #ffecec;
        border: 1px solid #f5c2c2;
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 16px;
        font-size: 13px;
    }
</style>