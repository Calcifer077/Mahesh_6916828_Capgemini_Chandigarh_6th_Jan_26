@model SmartHealthcare.Models.DTOs.DoctorDTO

@{
    ViewData["Title"] = "Doctor Profile";
}

<div class="page-container">

    <a href="@Url.Action("Index")" class="back-link">← Back to Doctors</a>

    <div class="profile-card">

        <!-- Header -->
        <div class="profile-header">
            <div>
                <h2>Dr. @Model.FullName</h2>
                <p class="muted">
                    @string.Join(", ", Model.Specializations ?? new List<string>())
                </p>
            </div>

            <div class="status">
                @(Model.IsAvailable ? "Available" : "Unavailable")
            </div>
        </div>

        <!-- Info Grid -->
        <div class="info-grid">

            <div class="info-block">
                <h4>Contact</h4>
                <p>Email: @Model.Email</p>
                <p>Phone: @Model.Phone</p>
                <p>License: @Model.LicenseNumber</p>
            </div>

            <div class="info-block">
                <h4>Details</h4>
                <p>Experience: @Model.YearsOfExperience years</p>
                <p>Fee: Rs. @Model.ConsultationFee</p>
            </div>

        </div>

        <!-- About -->
        <div class="section">
            <h4>About</h4>
            <p class="muted">
                Dr. @Model.FullName has @Model.YearsOfExperience years of experience 
                in @(Model.Specializations?.Count > 0 ? string.Join(", ", Model.Specializations) : "medical practice").
            </p>
        </div>

        <!-- Actions -->
        <div class="actions">
            @if (Context.Session.GetString("Role") == "Doctor")
            {
                <a asp-controller="Doctor" asp-action="Edit" class="btn primary">Edit</a>
            }

            @if (Model.IsAvailable)
            {
                <a asp-controller="Appointment" asp-action="Create" class="btn primary">Book Appointment</a>
            }

            <a href="@Url.Action("Index")" class="btn">Back</a>
        </div>

    </div>

</div>

<style>
    body {
        background: #f5f5f5;
        font-family: system-ui, -apple-system, sans-serif;
        color: #222;
    }

    .page-container {
        max-width: 700px;
        margin: 40px auto;
        padding: 0 16px;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 16px;
        text-decoration: none;
        color: #555;
        font-size: 14px;
    }

    .profile-card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 10px;
        padding: 24px;
    }

    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .profile-header h2 {
        margin: 0 0 4px;
        font-weight: 600;
    }

    .muted {
        color: #666;
        font-size: 14px;
    }

    .status {
        font-size: 13px;
        padding: 4px 10px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .info-block h4 {
        margin-bottom: 8px;
        font-size: 15px;
        color: #444;
    }

    .info-block p {
        margin: 4px 0;
        font-size: 14px;
    }

    .section {
        margin-bottom: 20px;
    }

    .section h4 {
        margin-bottom: 6px;
        font-size: 15px;
    }

    .actions {
        display: flex;
        gap: 10px;
    }

    .btn {
        padding: 8px 14px;
        border: 1px solid #ccc;
        border-radius: 6px;
        text-decoration: none;
        color: #222;
        background: #fff;
        font-size: 14px;
    }

    .btn.primary {
        background: #222;
        color: #fff;
        border-color: #222;
    }

    .btn:hover {
        background: #f0f0f0;
    }

    .btn.primary:hover {
        background: #000;
    }
</style>