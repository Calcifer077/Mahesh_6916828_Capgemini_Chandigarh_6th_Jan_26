@model SmartHealthcare.Models.DTOs.CreateDoctorDTO

@{
    ViewData["Title"] = "Complete Doctor Profile";
    var specializations = ViewBag.Specializations as IEnumerable<SmartHealthcare.Models.DTOs.SpecializationDTO> ?? Enumerable.Empty<SmartHealthcare.Models.DTOs.SpecializationDTO>();
}

<div class="page-container">

    <div class="form-container">
        <h2>Complete Doctor Profile</h2>
        <p class="subtitle">Fill in your details to start receiving appointments</p>

        <form asp-action="CreateProfile" method="post" novalidate>

            <div asp-validation-summary="All" class="error-box"></div>

            <!-- License -->
            <div class="form-group">
                <label asp-for="LicenseNumber">License Number</label>
                <input asp-for="LicenseNumber" class="input" />
                <span asp-validation-for="LicenseNumber" class="error"></span>
            </div>

            <!-- Experience + Fee -->
            <div class="row">
                <div class="form-group">
                    <label asp-for="YearsOfExperience">Experience (years)</label>
                    <input asp-for="YearsOfExperience" type="number" class="input" />
                    <span asp-validation-for="YearsOfExperience" class="error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConsultationFee">Fee (Rs)</label>
                    <input asp-for="ConsultationFee" type="number" step="0.01" class="input" />
                    <span asp-validation-for="ConsultationFee" class="error"></span>
                </div>
            </div>

            <!-- Phone -->
            <div class="form-group">
                <label asp-for="Phone">Phone</label>
                <input asp-for="Phone" class="input" />
                <span asp-validation-for="Phone" class="error"></span>
            </div>

            <!-- Specializations -->
            <div class="form-group">
                <label>Specializations</label>
                <div class="checkbox-grid">
                    @foreach (var spec in specializations)
                    {
                        <label class="checkbox-item">
                            <input type="checkbox" name="SpecializationIds" value="@spec.Id" />
                            @spec.Name
                        </label>
                    }
                </div>
                <span asp-validation-for="SpecializationIds" class="error"></span>
            </div>

            <!-- Availability -->
            <div class="form-group inline">
                <input asp-for="IsAvailable" type="checkbox" />
                <label asp-for="IsAvailable">Available for appointments</label>
            </div>

            <!-- Actions -->
            <div class="actions">
                <button type="submit" class="btn primary">Save</button>
                <a href="@Url.Action("Index", "Doctor")" class="btn">Cancel</a>
            </div>

        </form>
    </div>

</div>

<style>
    body {
        background: #f5f5f5;
        font-family: system-ui, -apple-system, sans-serif;
        color: #222;
    }

    .page-container {
        max-width: 700px;
        margin: 40px auto;
        padding: 0 16px;
    }

    .form-container {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 10px;
        padding: 24px;
    }

    h2 {
        margin-bottom: 4px;
        font-weight: 600;
    }

    .subtitle {
        color: #666;
        font-size: 14px;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        margin-bottom: 6px;
    }

    .input {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-size: 14px;
    }

    .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .checkbox-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 6px;
        margin-top: 6px;
    }

    .checkbox-item {
        font-size: 14px;
        color: #444;
    }

    .inline {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .actions {
        margin-top: 20px;
        display: flex;
        gap: 10px;
    }

    .btn {
        padding: 8px 14px;
        border: 1px solid #ccc;
        border-radius: 6px;
        text-decoration: none;
        color: #222;
        background: #fff;
        font-size: 14px;
    }

    .btn.primary {
        background: #222;
        color: #fff;
        border-color: #222;
    }

    .btn:hover {
        background: #f0f0f0;
    }

    .btn.primary:hover {
        background: #000;
    }

    .error {
        color: #c00;
        font-size: 12px;
    }

    .error-box {
        margin-bottom: 12px;
        font-size: 13px;
        color: #c00;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}