@model SmartHealthcare.Models.DTOs.LoginDTO
@{
    ViewData["Title"] = "Login";
}

<div class="login-container">
    <div class="login-card">

        <!-- Header -->
        <div class="login-header">
            <h2>Smart Healthcare</h2>
            <p>Sign in to your account</p>
        </div>

        <!-- Form -->
        <form asp-action="Login" method="post" novalidate>
            <div asp-validation-summary="All" class="error-box"></div>

            <!-- Email -->
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" placeholder="Email" />
                <span asp-validation-for="Email" class="error-text"></span>
            </div>

            <!-- Password -->
            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" class="form-input" placeholder="Password" />
                <span asp-validation-for="Password" class="error-text"></span>
            </div>

            <!-- Remember -->
            <div class="form-check">
                <input type="checkbox" id="rememberMe" />
                <label for="rememberMe">Remember me</label>
            </div>

            <!-- Button -->
            <button type="submit" class="btn-login">
                Login
            </button>

            <!-- Demo Info -->
            <div class="info-box">
                <strong>Demo:</strong><br />
                admin@healthcare.com / Admin@123
            </div>
        </form>

        <!-- Footer -->
        <div class="login-footer">
            <span>Don't have an account?</span>
            <a asp-action="Register">Register</a>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    body {
        background: #f7f7f7;
        font-family: system-ui, -apple-system, sans-serif;
        color: #222;
    }

    .login-container {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        width: 100%;
        max-width: 380px;
        background: #ffffff;
        padding: 32px;
        border-radius: 12px;
        border: 1px solid #e5e5e5;
    }

    .login-header {
        text-align: center;
        margin-bottom: 24px;
    }

    .login-header h2 {
        margin-bottom: 6px;
        font-weight: 600;
    }

    .login-header p {
        color: #777;
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        margin-bottom: 6px;
        color: #555;
    }

    .form-input {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 14px;
    }

    .form-input:focus {
        outline: none;
        border-color: #4a90e2;
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 16px;
        font-size: 14px;
        color: #555;
    }

    .btn-login {
        width: 100%;
        padding: 10px;
        border: none;
        background: #4a90e2;
        color: #fff;
        border-radius: 8px;
        font-size: 15px;
        cursor: pointer;
    }

    .btn-login:hover {
        background: #3a78c2;
    }

    .error-box {
        background: #ffecec;
        color: #d8000c;
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 16px;
        font-size: 13px;
    }

    .error-text {
        font-size: 12px;
        color: #d8000c;
    }

    .info-box {
        margin-top: 16px;
        font-size: 12px;
        color: #777;
    }

    .login-footer {
        text-align: center;
        margin-top: 20px;
        font-size: 14px;
    }

    .login-footer a {
        margin-left: 5px;
        color: #4a90e2;
        text-decoration: none;
    }

    .login-footer a:hover {
        text-decoration: underline;
    }
</style>