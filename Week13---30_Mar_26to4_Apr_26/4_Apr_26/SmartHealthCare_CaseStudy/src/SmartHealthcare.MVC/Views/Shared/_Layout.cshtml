<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Healthcare</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    @* <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> *@

    <style>
        body {
            background: #f5f5f5;
            font-family: system-ui, -apple-system, sans-serif;
            color: #222;
        }

        .navbar {
            background: #fff;
            border-bottom: 1px solid #e5e5e5;
        }

        .navbar-brand {
            font-weight: 600;
        }

        .nav-link {
            color: #444 !important;
        }

        .nav-link:hover {
            color: #000 !important;
        }

        .main-container {
            max-width: 900px;
            margin: 30px auto;
            padding: 0 16px;
        }

        .footer {
            text-align: center;
            padding: 20px;
            font-size: 13px;
            color: #777;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Smart Healthcare
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navBar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navBar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Doctor" asp-action="Index">Doctors</a>
                    </li>

                    @if (Context.Session.GetString("Token") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Appointment" asp-action="Index">Appointments</a>
                        </li>

                        @if (Context.Session.GetString("Role") == "Doctor")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Doctor" asp-action="Profile">Profile</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Patient" asp-action="Profile">Profile</a>
                            </li>
                        }
                    }
                </ul>

                <div class="d-flex gap-2">
                    @if (Context.Session.GetString("Token") != null)
                    {
                        <span class="text-muted small align-self-center">
                            @Context.Session.GetString("FullName")
                        </span>
                        <a class="btn btn-outline-secondary btn-sm" asp-controller="Account" asp-action="Logout">
                            Logout
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-outline-secondary btn-sm" asp-controller="Account" asp-action="Login">
                            Login
                        </a>
                        <a class="btn btn-dark btn-sm" asp-controller="Account" asp-action="Register">
                            Register
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Content -->
    <main class="main-container">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        &copy; 2026 Smart Healthcare
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>